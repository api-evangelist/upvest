{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/upvest/refs/heads/main/json-schema/investment-api-fee-schema.json",
  "title": "Fee",
  "description": "A fee charged on an account.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "The fee identifier.",
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    "account_id": {
      "type": "string",
      "format": "uuid",
      "description": "The account the fee was charged on.",
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    "type": {
      "type": "string",
      "description": "The fee type.",
      "example": "standard"
    },
    "amount": {
      "type": "string",
      "description": "The fee amount as a decimal string.",
      "example": "example-value"
    },
    "currency": {
      "type": "string",
      "description": "The fee currency.",
      "pattern": "^[A-Z]{3}$",
      "example": "EUR"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the fee was charged.",
      "example": "2025-03-15T14:30:00Z"
    }
  }
}