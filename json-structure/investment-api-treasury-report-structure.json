{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/upvest/refs/heads/main/json-structure/investment-api-treasury-report-structure.json",
  "name": "TreasuryReport",
  "description": "A treasury-level report for institutional oversight.",
  "type": "object",
  "properties": {
    "id": {
      "type": "uuid",
      "description": "The treasury report identifier.",
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    "type": {
      "type": "string",
      "description": "The report type.",
      "example": "standard"
    },
    "file_id": {
      "type": "uuid",
      "description": "The file identifier for downloading the report.",
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    "created_at": {
      "type": "datetime",
      "description": "When the report was generated.",
      "example": "2025-03-15T14:30:00Z"
    }
  }
}