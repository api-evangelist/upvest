{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/upvest/refs/heads/main/json-structure/investment-api-withdrawal-create-structure.json",
  "name": "WithdrawalCreate",
  "description": "Request body for creating a withdrawal.",
  "type": "object",
  "properties": {
    "account_id": {
      "type": "uuid",
      "description": "The account to withdraw from.",
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    "cash_amount": {
      "type": "string",
      "description": "The withdrawal amount.",
      "example": "example-value"
    },
    "currency": {
      "type": "string",
      "description": "The currency as an ISO 4217 code.",
      "pattern": "^[A-Z]{3}$",
      "example": "EUR"
    }
  },
  "required": [
    "account_id",
    "cash_amount",
    "currency"
  ]
}